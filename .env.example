# cp .env.example .env
# Required for M4 (RAGAS eval) and M5 (Enrichment LLM calls)
OPENAI_API_KEY=sk-...
# ============================================================
# Lab 18 — Production RAG — biến môi trường
# ============================================================

# --- Gemini (M4 RAGAS judge, M5 enrichment, LLM answer) ---
# Lấy key tại: https://aistudio.google.com/apikey  → dán vào đây:
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
# Endpoint OpenAI-compat của Gemini chỉ hỗ trợ gemini-embedding-001 (KHÔNG có text-embedding-004)
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- Qdrant Cloud (M2 Dense Search) ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_CLUSTER_ENDPOINT=
QDRANT_CLUSTER_ID=
